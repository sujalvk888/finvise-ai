# ============================================================
# FinVise.AI Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Database ---
# Supabase PostgreSQL: Project → Settings → Database → Connection String (URI)
# Use the connection pooling string for Render deployments.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:5432/postgres

# --- JWT Authentication ---
# Generate a secure random string (32+ characters) for production.
# Example: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your_very_long_and_random_secret_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Google OAuth (optional — only needed if Google Login is enabled) ---
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# --- CORS Origins ---
# Comma-separated list of allowed frontend URLs.
# For production, set this to your Vercel deployment URL.
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# --- Deployment URLs ---
FRONTEND_URL=https://your-app.vercel.app
BACKEND_URL=https://your-api.onrender.com

# --- Third-Party APIs ---
# Get a free Finnhub API key at https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_api_key_here

# Get a free Groq API key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# --- Environment ---
# Set to "production" on Render to disable /docs endpoint
ENVIRONMENT=development