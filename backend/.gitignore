# ============================================================
# FinVise.AI Backend — .gitignore
# ============================================================

# Virtual environment
venv/
.venv/
env/

# Python bytecode
__pycache__/
*.pyc
*.pyo
*.pyd
*.pycache

# Environment variables — NEVER commit secrets
.env
.env.*
!.env.example

# Database files
*.db
*.sqlite3

# Logs
*.log
logs/

# pytest
.pytest_cache/
.coverage
htmlcov/

# Distribution
dist/
build/
*.egg-info/

# OS
.DS_Store
Thumbs.db
